{
  "name": "vibecoder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "vite --mode full",
    "build": "tsc --noEmit && vite build",
    "build:demo": "tsc --noEmit && vite build --mode demo",
    "build:full": "tsc --noEmit && vite build --mode full",
    "check": "tsc --noEmit && eslint . && prettier --check . && vitest run && npm run validate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "sim": "node --no-warnings --experimental-strip-types --experimental-loader ./tools/sim/ts-loader.mjs tools/sim/index.ts",
    "tauri": "tauri",
    "validate": "node --experimental-strip-types src/dev/validate.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.13.2",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.4",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@wllama/wllama": "3.5.0"
  }
}
