{
  "name": "vibecoder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit && eslint . && prettier --check . && vitest run && npm run validate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "validate": "node --experimental-strip-types src/dev/validate.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.13.2",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
